PORT=5000

# CORS — set this before deploying
# Leave empty = localhost only (dev default)
# Use * = allow all origins (open/public deployment)
# Use https://yourdomain.com = single origin (production lockdown)
# Use https://a.com,https://b.com = multiple origins
ALLOWED_ORIGIN=

API_TIMEOUT_MS=8000
MAX_API_CALLS=5
MAX_RETRIES=2
RETRY_DELAY_MS=500
PAGE_SIZE=10

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Logging
LOG_LEVEL=info
NODE_ENV=development
